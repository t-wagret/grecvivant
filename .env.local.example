# ── Supabase ────────────────────────────────────────────────────────────────
# Dashboard Supabase → Project Settings → API
#   - "Project URL"            → NEXT_PUBLIC_SUPABASE_URL
#   - "anon" / "publishable"   → NEXT_PUBLIC_SUPABASE_ANON_KEY
# Ces deux valeurs sont publiques (exposées au navigateur) ; ce sont les
# politiques RLS (supabase/schema.sql) qui protègent réellement les données.

NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_CLE_ANON_PUBLISHABLE

# ── Site ─────────────────────────────────────────────────────────────────────
# URL publique du site (utile pour les liens de confirmation d'e-mail Supabase).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
